{
  "cSpell.words": [
    "cloudinary",
    "clsx",
    "Contentlayer",
    "fontsource",
    "frontmatter",
    "giscus",
    "headlessui",
    "hookform",
    "Katex",
    "langliu",
    "Lucide",
    "nextjs",
    "rehype",
    "supabase",
    "tailwindcss",
    "tanstack",
    "turbopack"
  ],
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "css.validate": true,
  "css.lint.unknownAtRules": "ignore",
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit"
  }
}
